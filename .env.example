# =============================================================================
# AI Platform Configuration Example
# =============================================================================
# Copy this file to .env and customize for your environment
# DO NOT commit the actual .env file with real secrets
# =============================================================================

# ── Core Paths ────────────────────────────────────────────────────────────────
MNT_BASE=/mnt/aiplatform
REPO_ROOT=/home/user/AIPlatformAutomation

# ── Network ───────────────────────────────────────────────────────────────────
DOMAIN=local
HOST_IP=192.168.1.100
BIFROST_SUBNET=172.20.0.0/16
BIFROST_GATEWAY=172.20.0.1
BIFROST_MTU=1450

# ── GPU ───────────────────────────────────────────────────────────────────────
GPU_TYPE=cpu
OLLAMA_RUNTIME=cpu

# ── Portainer ─────────────────────────────────────────────────────────────────
PORTAINER_CONTAINER_NAME=portainer
PORTAINER_PORT=9443
PORTAINER_HTTP_PORT=8000
PORTAINER_ADMIN_PASSWORD=your-secure-password-here

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_CONTAINER_NAME=ollama
OLLAMA_PORT=11434
OLLAMA_DEFAULT_MODEL=llama3.2
OLLAMA_PULL_DEFAULT_MODEL=true

# ── Open WebUI ────────────────────────────────────────────────────────────────
OPEN_WEBUI_CONTAINER_NAME=open-webui
OPEN_WEBUI_PORT=3000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_CONTAINER_NAME=postgres
POSTGRES_PORT=5432
POSTGRES_USER=aiplatform
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=aiplatform
N8N_DB=n8n
FLOWISE_DB=flowise

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_CONTAINER_NAME=redis
REDIS_PORT=6379
REDIS_PASSWORD=your-secure-password-here

# ── n8n ───────────────────────────────────────────────────────────────────────
N8N_CONTAINER_NAME=n8n
N8N_PORT=5678
N8N_WEBHOOK_URL=http://192.168.1.100:5678
N8N_ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here

# ── SearXNG ───────────────────────────────────────────────────────────────────
SEARXNG_CONTAINER_NAME=searxng
SEARXNG_PORT=8080
SEARXNG_SECRET_KEY=your-32-byte-hex-secret-key-here

# ── Flowise ───────────────────────────────────────────────────────────────────
FLOWISE_CONTAINER_NAME=flowise
FLOWISE_PORT=3001
FLOWISE_USERNAME=admin
FLOWISE_PASSWORD=your-secure-password-here

# ── Nginx ─────────────────────────────────────────────────────────────────────
ENABLE_NGINX=true
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
